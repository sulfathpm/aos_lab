#include <stdio.h>
#include <pthread.h>
#include <semaphore.h>

sem_t mutex;
int shared = 0;

void *process()
{
    sem_wait(&mutex);

    printf("Entering critical section\n");
    shared++;
    printf("Shared value: %d\n", shared);

    printf("Leaving critical section\n");

    sem_post(&mutex);
}

int main()
{
    pthread_t t1,t2;

    sem_init(&mutex,0,1);

    pthread_create(&t1,NULL,process,NULL);
    pthread_create(&t2,NULL,process,NULL);

    pthread_join(t1,NULL);
    pthread_join(t2,NULL);

    sem_destroy(&mutex);

    return 0;
}
